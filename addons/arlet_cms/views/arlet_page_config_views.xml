<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Page Config list ──────────────────────────────────────────── -->
    <record id="arlet_page_config_list_view" model="ir.ui.view">
        <field name="name">arlet.page.config.list</field>
        <field name="model">arlet.page.config</field>
        <field name="arch" type="xml">
            <list string="Page Configurations" create="false" delete="false">
                <field name="page_key"/>
            </list>
        </field>
    </record>

    <!-- ── Page Config form ──────────────────────────────────────────── -->
    <record id="arlet_page_config_form_view" model="ir.ui.view">
        <field name="name">arlet.page.config.form</field>
        <field name="model">arlet.page.config</field>
        <field name="arch" type="xml">
            <form string="Page Configuration" create="false" delete="false">
                <sheet>
                    <group>
                        <field name="page_key"/>
                        <field name="hubspot_form_id"
                               options="{'no_create': True}"
                               placeholder="Select a synced HubSpot form"
                               invisible="page_key not in ['contact-us', 'join-arlet', 'arlet-x-business']"/>
                        <field name="featured_article_id"
                               options="{'no_create': True}"
                               domain="[('status', '=', 'published')]"
                               invisible="page_key not in ['meet-arlet', 'meet-marie', 'our-pillars']"/>
                    </group>
                    <separator string="Testimonial Profiles"
                               invisible="page_key != 'join-arlet'"/>
                    <field name="testimonial_profile_ids" nolabel="1"
                           invisible="page_key != 'join-arlet'">
                        <list string="Testimonial Profiles">
                            <field name="name"/>
                            <field name="title"/>
                            <field name="label"/>
                        </list>
                    </field>
                    <separator string="Featured Events"
                               invisible="page_key != 'join-arlet'"/>
                    <field name="featured_event_ids" nolabel="1"
                           invisible="page_key != 'join-arlet'">
                        <list string="Featured Events">
                            <field name="name"/>
                            <field name="start_date"/>
                            <field name="location"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="arlet_page_config_action" model="ir.actions.act_window">
        <field name="name">Page Configurations</field>
        <field name="res_model">arlet.page.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
