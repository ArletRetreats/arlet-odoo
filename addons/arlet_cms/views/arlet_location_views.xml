<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Location list ─────────────────────────────────────────────── -->
    <record id="arlet_location_list_view" model="ir.ui.view">
        <field name="name">arlet.location.list</field>
        <field name="model">arlet.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="name"/>
                <field name="country"/>
                <field name="image_position"/>
            </list>
        </field>
    </record>

    <!-- ── Location form ─────────────────────────────────────────────── -->
    <record id="arlet_location_form_view" model="ir.ui.view">
        <field name="name">arlet.location.form</field>
        <field name="model">arlet.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="country" placeholder="BE"/>
                            <field name="image" placeholder="https://..."/>
                            <field name="image_alt"/>
                            <field name="image_position"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content (EN)">
                            <group>
                                <field name="subtitle"/>
                            </group>
                            <field name="html" widget="html"/>
                        </page>
                        <page string="Translations">
                            <field name="translation_ids">
                                <list string="Translations">
                                    <field name="locale"/>
                                    <field name="subtitle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="arlet_location_action" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">arlet.location</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
