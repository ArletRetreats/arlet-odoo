<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Content Block Translation form (popup) ────────────────────── -->
    <record id="arlet_content_block_translation_form_view" model="ir.ui.view">
        <field name="name">arlet.content.block.translation.form</field>
        <field name="model">arlet.content.block.translation</field>
        <field name="arch" type="xml">
            <form string="Block Translation">
                <sheet>
                    <field name="block_type" invisible="1"/>
                    <group>
                        <field name="locale"/>
                    </group>
                    <group invisible="block_type in ('image', 'profile', 'location', 'program', 'form')">
                        <field name="title"/>
                        <field name="label"    invisible="block_type in ('testimonial', 'profiles', 'occasion')"/>
                        <field name="subtitle" invisible="block_type == 'occasion'"/>
                    </group>
                    <separator string="HTML Body"
                               invisible="block_type in ('image', 'profile', 'location', 'program', 'form', 'occasion', 'profiles', 'testimonial')"/>
                    <field name="html" widget="html" nolabel="1"
                           invisible="block_type in ('image', 'profile', 'location', 'program', 'form', 'occasion', 'profiles', 'testimonial')"/>
                    <group invisible="block_type in ('image', 'profile', 'location', 'program', 'form')">
                        <field name="paragraphs" placeholder="One paragraph per line (used if HTML empty)"
                               invisible="block_type in ('occasion', 'profiles')"/>
                        <field name="footer"     placeholder="One footer line per line"
                               invisible="block_type == 'profiles'"/>
                        <field name="left_items"  placeholder="Left column — one item per line"
                               invisible="block_type != 'occasion'"/>
                        <field name="right_items" placeholder="Right column — one item per line"
                               invisible="block_type != 'occasion'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Content Block form ────────────────────────────────────────── -->
    <record id="arlet_content_block_form_view" model="ir.ui.view">
        <field name="name">arlet.content.block.form</field>
        <field name="model">arlet.content.block</field>
        <field name="arch" type="xml">
            <form string="Content Block">
                <sheet>
                    <group>
                        <group string="Layout">
                            <field name="type"/>
                            <field name="sequence"/>
                            <field name="bg"/>
                            <field name="text_color"/>
                            <field name="padding_y"/>
                            <field name="image_position" invisible="type not in ('split', 'half', 'testimonial')"/>
                        </group>
                        <group string="Media" invisible="type not in ('cover', 'split', 'testimonial', 'image')">
                            <field name="bg_image" widget="image" options="{'size': [128, 128]}" invisible="type != 'cover'"/>
                            <field name="image"    widget="image" options="{'size': [128, 128]}" invisible="type not in ('split', 'testimonial', 'image')"/>
                            <field name="image_alt" invisible="type not in ('split', 'testimonial', 'image')"/>
                        </group>
                    </group>

                    <!-- Relation selectors — shown contextually per block type -->
                    <group string="Profile" invisible="type not in ('profile', 'testimonial')">
                        <field name="profile_id" options="{'no_create': True}"/>
                    </group>
                    <group string="Profiles" invisible="type != 'profiles'">
                        <field name="profile_ids" nolabel="1" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                    <group string="Location" invisible="type != 'location'">
                        <field name="location_id" options="{'no_create': True}"/>
                    </group>
                    <group string="Event (Program)" invisible="type != 'program'">
                        <field name="event_id" options="{'no_create': True}"/>
                    </group>
                    <group string="HubSpot Form" invisible="type != 'form'">
                        <field name="hubspot_form_id" options="{'no_create': True}"/>
                    </group>

                    <notebook>
                        <page string="Content (EN)" invisible="type in ('image', 'profile', 'location', 'program', 'cards')">
                            <group>
                                <field name="title"/>
                                <field name="label"    invisible="type in ('testimonial', 'profiles', 'occasion')"/>
                                <field name="subtitle"/>
                            </group>
                            <field name="html" widget="html" invisible="type in ('occasion', 'profiles', 'testimonial')"/>
                            <group>
                                <field name="paragraphs"  placeholder="One paragraph per line (used if HTML empty)" invisible="type in ('occasion', 'profiles')"/>
                                <field name="footer"      placeholder="One footer line per line"                     invisible="type == 'profiles'"/>
                                <field name="left_items"  placeholder="Left column — one item per line"             invisible="type != 'occasion'"/>
                                <field name="right_items" placeholder="Right column — one item per line"            invisible="type != 'occasion'"/>
                            </group>
                        </page>
                        <page string="Translations">
                            <field name="translation_ids" context="{'form_view_ref': 'arlet_cms.arlet_content_block_translation_form_view'}">
                                <list string="Translations">
                                    <field name="locale"/>
                                    <field name="title"/>
                                    <field name="subtitle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Cards (EN)" invisible="type != 'cards'">
                            <field name="card_ids" context="{'form_view_ref': 'arlet_cms.arlet_content_block_card_form_view'}">
                                <list string="Cards">
                                    <field name="sequence" widget="handle"/>
                                    <field name="title"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Content Block Card form (popup) ───────────────────────────── -->
    <record id="arlet_content_block_card_form_view" model="ir.ui.view">
        <field name="name">arlet.content.block.card.form</field>
        <field name="model">arlet.content.block.card</field>
        <field name="arch" type="xml">
            <form string="Card">
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="title"/>
                    </group>
                    <field name="html" widget="html"/>
                    <notebook>
                        <page string="Translations">
                            <field name="translation_ids">
                                <list string="Translations" editable="bottom">
                                    <field name="locale"/>
                                    <field name="title"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Profile list ──────────────────────────────────────────────── -->
    <record id="arlet_profile_list_view" model="ir.ui.view">
        <field name="name">arlet.profile.list</field>
        <field name="model">arlet.profile</field>
        <field name="arch" type="xml">
            <list string="Profiles">
                <field name="name"/>
                <field name="title"/>
                <field name="label"/>
            </list>
        </field>
    </record>

    <!-- ── Profile form ──────────────────────────────────────────────── -->
    <record id="arlet_profile_form_view" model="ir.ui.view">
        <field name="name">arlet.profile.form</field>
        <field name="model">arlet.profile</field>
        <field name="arch" type="xml">
            <form string="Profile">
                <sheet>
                    <group>
                        <group string="Identity">
                            <field name="name"/>
                            <field name="title"/>
                            <field name="label"/>
                            <field name="slug" readonly="1"/>
                        </group>
                        <group string="Media">
                            <field name="image" widget="image" options="{'size': [128, 128]}"/>
                            <field name="image_alt"/>
                            <field name="image_caption"/>
                        </group>
                    </group>
                    <group string="Host Page Hero" col="2">
                        <field name="hero_bg" widget="image" options="{'size': [128, 128]}" help="Hero background for /events/host/&lt;slug&gt;. Falls back to Photo when empty."/>
                        <field name="hero_bg_alt" placeholder="Alt text for hero background"/>
                    </group>
                    <notebook>
                        <page string="Content (EN)">
                            <field name="html" widget="html"/>
                            <group>
                                <field name="list_label"/>
                                <field name="list_items" placeholder="One certification per line"/>
                            </group>
                        </page>
                        <page string="Translations">
                            <field name="translation_ids">
                                <list string="Translations" editable="bottom">
                                    <field name="locale"/>
                                    <field name="list_label"/>
                                    <field name="list_items"/>
                                </list>
                            </field>
                        </page>
                        <page string="Links">
                            <field name="link_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="label"/>
                                    <field name="value"/>
                                    <field name="href"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Article list ──────────────────────────────────────────────── -->
    <record id="arlet_article_list_view" model="ir.ui.view">
        <field name="name">arlet.article.list</field>
        <field name="model">arlet.article</field>
        <field name="arch" type="xml">
            <list string="Articles">
                <field name="name"/>
                <field name="status"/>
                <field name="title"/>
                <field name="badge"/>
                <field name="published_at"/>
                <field name="slug"/>
            </list>
        </field>
    </record>

    <!-- ── Article form ──────────────────────────────────────────────── -->
    <record id="arlet_article_form_view" model="ir.ui.view">
        <field name="name">arlet.article.form</field>
        <field name="model">arlet.article</field>
        <field name="arch" type="xml">
            <form string="Article">
                <header>
                    <button name="action_preview" string="Preview on Web" type="object"
                            class="btn-primary" invisible="not slug"/>
                </header>
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="status"/>
                            <field name="published_at"/>
                            <field name="author"/>
                            <field name="location"/>
                            <field name="slug" readonly="1"/>
                        </group>
                        <group string="Cover Image">
                            <field name="image"   widget="image" options="{'size': [128, 128]}"/>
                            <field name="hero_bg" widget="image" options="{'size': [128, 128]}" help="Detail page hero background"/>
                            <field name="hero_bg_alt"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content (EN)">
                            <group>
                                <field name="badge"/>
                                <field name="title"/>
                                <field name="subtitle"/>
                                <field name="description"/>
                                <field name="intro" placeholder="One intro paragraph per line"/>
                            </group>
                        </page>
                        <page string="Translations">
                            <field name="translation_ids">
                                <list editable="bottom" string="Translations">
                                    <field name="locale"/>
                                    <field name="badge"/>
                                    <field name="title"/>
                                    <field name="subtitle"/>
                                    <field name="description"/>
                                    <field name="intro"/>
                                </list>
                            </field>
                        </page>
                        <page string="Content Blocks">
                            <field name="content_ids">
                                <list string="Blocks">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type"/>
                                    <field name="title"/>
                                    <field name="bg"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Actions ───────────────────────────────────────────────────── -->
    <record id="arlet_article_action" model="ir.actions.act_window">
        <field name="name">Articles</field>
        <field name="res_model">arlet.article</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="arlet_profile_action" model="ir.actions.act_window">
        <field name="name">Profiles</field>
        <field name="res_model">arlet.profile</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
