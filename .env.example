# =============================================================================
# Arlet Odoo — Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# =============================================================================

# PostgreSQL
POSTGRES_DB=arlet_odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me_strong_password

# Odoo master password (used to create/drop DBs via web UI — keep secret)
ODOO_MASTER_PASSWORD=change_me_strong_password

# AWS S3 (for Odoo file/attachment storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_BUCKETNAME=arlet-odoo-storage

# Public URLs
ARLET_API_KEY=
ARLET_ODOO_BASE=https://odoo.arletretreats.com
ARLET_WEB_BASE=https://arlet.co
